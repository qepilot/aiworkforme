# Create a free project at https://supabase.com, then go to
# Project Settings -> API and copy these two values.
#
# NEXT_PUBLIC_SUPABASE_ANON_KEY is safe to expose in the browser by design —
# Supabase's security model relies on Row Level Security policies on your
# database tables, not on keeping this key secret.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Also run supabase/migrations/0001_integrations_and_sources.sql against
# your project before using /dashboard/integrations or /dashboard/sources.

# Server-only key used to encrypt integration credentials (AES-256-GCM)
# before they're stored. Generate with: openssl rand -base64 32
# Never expose this as NEXT_PUBLIC_*.
ENCRYPTION_KEY=

# Create a free GA4 property at https://analytics.google.com and paste its
# Measurement ID (looks like G-XXXXXXXXXX) here. Google Analytics is only
# loaded when this is set — leave it blank to disable tracking entirely.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
